    RowBox[{"ContourShading", "\[Rule]", "False"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"ContourStyle", "\[Rule]", "Green"}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.506610183925736*^9, {3.506610627300144*^9, 3.506610629920641*^9}}]
}, Closed]],

