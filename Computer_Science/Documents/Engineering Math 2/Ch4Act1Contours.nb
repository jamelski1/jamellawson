Cell[CellGroupData[{

Cell[TextData[{
 "Plot the tangent and contour near the fixed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]]],
 " but ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", "1"}], "/", "10"}], TraditionalForm]]]
}], "Solution",
 CellChangeTimes->{{3.506007211713401*^9, 3.5060072183600473`*^9}, {
  3.506007307668482*^9, 3.506007317571734*^9}, {3.506007372757161*^9, 
  3.5060073803732443`*^9}, {3.5060074541529284`*^9, 3.506007462199863*^9}, {
  3.50600750921111*^9, 3.506007573004529*^9}, {3.506606308941634*^9, 
  3.506606334992792*^9}, {3.506607058201489*^9, 3.506607109224617*^9}, {
  3.506607329898032*^9, 3.506607337352161*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "=", 
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Delta]", "=", 
    RowBox[{"1", "/", "10"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"singleCurve", "=", 
    RowBox[{"ContourPlot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{"x", "+", "dx"}], ",", 
         RowBox[{"y", "+", "dy"}]}], "]"}], "\[Equal]", 
       RowBox[{"f", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"dx", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"dy", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"ContourStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Green"}], 
        "}"}]}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<dx\>\"", ",", "\"\<dy\>\""}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"singleLine", "=", 
    RowBox[{"ContourPlot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"dz", "[", 
        RowBox[{"dx", ",", "dy"}], "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{"{", 
       RowBox[{"dx", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"dy", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"ContourStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Magenta"}], 
        "}"}]}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<dx\>\"", ",", "\"\<dy\>\""}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"dFrame2D", "[", "\[Delta]", "]"}], ",", "singleCurve", ",", 
    "singleLine", ",", 
    RowBox[{"Arrow2D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"gradf", "[", 
        RowBox[{"x", ",", "y"}], "]"}], "/", "30"}], ",", "Orange"}], "]"}]}],
    "}"}], "]"}]}], "Input",
 CellChangeTimes->{{3.506007386538601*^9, 3.506007427216943*^9}, {
   3.506007472283736*^9, 3.506007476813799*^9}, {3.5060076181164217`*^9, 
