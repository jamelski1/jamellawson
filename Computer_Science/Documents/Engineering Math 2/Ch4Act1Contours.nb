Cell[BoxData[
 RowBox[{"topo", "=", 
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "2"}], ",", "4"}], "}"}], ",", 
