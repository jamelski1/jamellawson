Cell[TextData[{
 "Then work the steps with ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " below."
}], "Text",
 CellChangeTimes->{3.506610586054182*^9}],

Cell[CellGroupData[{

Cell["Define the function", "Solution",
 CellChangeTimes->{{3.506007211713401*^9, 3.5060072183600473`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{
   "x", ",", "y", ",", "dx", ",", "dy", ",", "f", ",", "fX", ",", "fY", ",", 
    "gradf"}], "]"}], ";"}], "\n", 
 RowBox[{"Needs", "[", "\"\<iMultiCalc`iMCUtilities`\>\"", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["x", "2"], "y"}], "-", 
     RowBox[{"x", " ", 
      SuperscriptBox["y", "2"]}]}], ")"}], "/", "3"}]}]}], "Input",
 CellChangeTimes->{{3.506955634460526*^9, 3.5069556415304327`*^9}}]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
Define the partial derivative functions & gradient vector\
\>", "Solution",
 CellChangeTimes->{{3.506007211713401*^9, 3.5060072183600473`*^9}, {
  3.506007307668482*^9, 3.506007317571734*^9}, {3.506007372757161*^9, 
  3.5060073803732443`*^9}, {3.506604709403433*^9, 3.506604713088533*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fX", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], "=", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], ",", "x"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fY", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], "=", 
  RowBox[{"??", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"??", ";"}], "\[IndentingNewLine]", 
      RowBox[{"gradf", "[", 
       RowBox[{"x_", ",", "y_"}], "]"}]}], "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"fX", "[", 
        RowBox[{"x", ",", "y"}], "]"}], ",", 
       RowBox[{"fY", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[Del]f[x,y]=\>\"", ",", 
      RowBox[{"MatrixForm", "[", 
       RowBox[{"gradf", "[", 
        RowBox[{"x", ",", "y"}], "]"}], "]"}]}], "]"}]}]}]}]}], "Input",
 CellChangeTimes->{{3.506610163522678*^9, 3.5066101646872473`*^9}, {
  3.5066109318287888`*^9, 3.5066109876090612`*^9}, {3.507305562204164*^9, 
  3.5073055653214893`*^9}}]
}, Closed]],

