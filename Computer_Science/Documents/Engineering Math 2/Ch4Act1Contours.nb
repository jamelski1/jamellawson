Notebook[{
Cell["\<\
In class activity for Chapter 4 Section 2\
\>", "Subsection",
 CellChangeTimes->{{3.494144502955161*^9, 3.494144510153487*^9}, 
   3.494144747737177*^9, {3.5028176873212976`*^9, 3.5028177051687193`*^9}, {
   3.503413108516704*^9, 3.5034131151717987`*^9}, {3.503413202713016*^9, 
   3.503413215718628*^9}, {3.5034134741844788`*^9, 3.503413489759516*^9}, {
   3.503413913080511*^9, 3.503413921397524*^9}, {3.506609188264792*^9, 
   3.506609190998227*^9}}],

Cell[CellGroupData[{

Cell["", "ExerciseSet",
 CounterAssignments->{{"Chapter", 4}, {"Section", 2}, {"Exercise", 5}}],

Cell[CellGroupData[{

Cell["", "Exercise"],

Cell[TextData[{
 "On paper, compute the gradient of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], "=", 
    RowBox[{
     FractionBox["1", "3"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["x", "2"], "y"}], "-", 
       RowBox[{"x", " ", 
        SuperscriptBox["y", "2"]}]}], ")"}]}]}], TraditionalForm]]],
 " at the points ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"x", ",", "y"}], ")"}], "=", 
     RowBox[{"(", 
      RowBox[{"2", ",", "1"}], ")"}]}], ",", " ", 
    RowBox[{"(", 
     RowBox[{"1", ",", 
      RowBox[{"-", "2"}]}], ")"}], ",", " ", 
    RowBox[{"(", 
     RowBox[{"2", ",", 
      RowBox[{"-", "1"}]}], ")"}]}], TraditionalForm]]],
 " and sketch the gradient with its tail at each respective point on your \
sketch of the contour graph.  "
}], "Text",
 CellChangeTimes->{{3.5066099804979773`*^9, 3.506609990822671*^9}, {
  3.506610024674891*^9, 3.506610042673073*^9}, {3.50661052548363*^9, 
  3.506610582525872*^9}, {3.506610907592901*^9, 3.506610915669117*^9}, {
  3.50667899708471*^9, 3.506679000723123*^9}}],

