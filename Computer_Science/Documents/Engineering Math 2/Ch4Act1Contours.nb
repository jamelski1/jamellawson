  3.5066061253930197`*^9}, {3.506606918721266*^9, 3.506606921415235*^9}}],

Cell[CellGroupData[{

Cell[TextData[{
 "Complete the following commands to make a contour plot of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "[", 
    RowBox[{
     RowBox[{"x", "+", 
      RowBox[{"d", "\[VeryThinSpace]", "x"}]}], ",", 
     RowBox[{"y", "+", 
      RowBox[{"d", "\[VeryThinSpace]", "y"}]}]}], "]"}], TraditionalForm]],
  FormatType->"TraditionalForm"],
 " near the fixed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]],
  FormatType->"TraditionalForm"],
 "-point, varying the difference values to nearby points by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "2"}], TraditionalForm]],
  FormatType->"TraditionalForm"],
 "."
}], "Text",
 CellChangeTimes->{{3.506605609740321*^9, 3.5066057557563353`*^9}, {
  3.506605827892723*^9, 3.5066058460800447`*^9}, {3.506605978986084*^9, 
  3.506606012870075*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"y", "=", 
  RowBox[{"??", 
   RowBox[{";", "\[IndentingNewLine]", 
    RowBox[{"z", "=", 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], "\[IndentingNewLine]", 
      RowBox[{"\[Delta]", "=", "2"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"contours", "=", 
     RowBox[{"ContourPlot", "[", 
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{"x", "+", "dx"}], ",", 
         RowBox[{"y", "+", "dy"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"dx", ",", 
         RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"dy", ",", 
         RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
       RowBox[{"FrameLabel", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"\"\<dx\>\"", ",", "\"\<dy\>\""}], "}"}]}]}], 
      "]"}]}]}]}]}]}], "Input",
 CellChangeTimes->{{3.506007386538601*^9, 3.506007427216943*^9}, {
