Cell[CellGroupData[{

Cell[TextData[{
 "Next, enter the next set of commands to plot just the single contour thru \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "[", 
    RowBox[{"3", ",", "2"}], "]"}], TraditionalForm]],
  FormatType->"TraditionalForm"],
 ":"
}], "Text",
 CellChangeTimes->{{3.506606041977796*^9, 3.506606076014585*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"singleCurve", "=", 
   RowBox[{"ContourPlot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{
        RowBox[{"x", "+", "dx"}], ",", 
        RowBox[{"y", "+", "dy"}]}], "]"}], "\[Equal]", 
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"dx", ",", 
       RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"dy", ",", 
       RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
     RowBox[{"ContourStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Green"}], "}"}]}],
      ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<dx\>\"", ",", "\"\<dy\>\""}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"singleCurve", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"dFrame2D", "[", "\[Delta]", "]"}], ",", "singleCurve", ",", 
     RowBox[{"Graphics", "[", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"AbsolutePointSize", "[", "5", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"Point", "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}], "]"}], "}"}]}], "}"}], "]"}]}], 
    "}"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.506007386538601*^9, 3.506007427216943*^9}, {
   3.506007472283736*^9, 3.506007476813799*^9}, {3.506007747954912*^9, 
