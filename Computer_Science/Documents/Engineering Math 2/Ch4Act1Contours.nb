 CellChangeTimes->{{3.506009008114458*^9, 3.506009026881851*^9}, {
  3.5060090590185204`*^9, 3.506009059019257*^9}}],

Cell[CellGroupData[{

Cell["Contour & Tangent", "Exercise"],

Cell["For each of the functions below:", "Text"],

Cell[TextData[{
 "1)  Sketch the contour ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], "=", "c"}], TraditionalForm]]],
 " through the given point ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]]],
 "."
}], "DisplayText"],

Cell[TextData[{
 "2)  Sketch the line tangent to the contour ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], "=", "c"}], TraditionalForm]]],
 " at the given point ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]]],
 "."
}], "DisplayText"],

Cell[TextData[{
 "3)  Give the specific local ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"dx", ",", "dy"}], ")"}], TraditionalForm]]],
 "-equations of that line."
}], "DisplayText"],

Cell[TextData[{
 "4)  Give the specific ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]]],
 "-equations of that line."
}], "DisplayText"],

Cell[TextData[{
 "c)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], "=", 
    RowBox[{"x", " ", "y"}]}], TraditionalForm]]],
 "  at the point  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", ",", "y"}], ")"}], " ", "=", " ", 
    RowBox[{"(", 
     RowBox[{"3", ",", "2"}], ")"}]}], TraditionalForm]]]
}], "SolnIndentedText"],

Cell[CellGroupData[{

Cell["Define the function", "Solution",
 CellChangeTimes->{{3.506007211713401*^9, 3.5060072183600473`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{
   "x", ",", "y", ",", "z", ",", "dx", ",", "dy", ",", "dz", ",", "f"}], 
   "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Needs", "[", "\"\<iMultiCalc`iMCUtilities`\>\"", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], "=", 
  RowBox[{"x", " ", "y"}]}]}], "Input",
 CellChangeTimes->{{3.506007263931981*^9, 3.506007294351605*^9}, {
  3.5060074036245737`*^9, 3.506007416378564*^9}, {3.50600764122488*^9, 
  3.506007661777419*^9}, {3.506007718285499*^9, 3.506007735397257*^9}, {
  3.506007786287396*^9, 3.506007812098827*^9}, {3.506008029670063*^9, 
  3.506008037518619*^9}, {3.506604583950099*^9, 3.5066045844101353`*^9}, {
  3.506604646099285*^9, 3.5066046490351467`*^9}, {3.506604971773835*^9, 
  3.5066049756278687`*^9}}]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
Define the partial derivative functions & gradient vector\
\>", "Solution",
 CellChangeTimes->{{3.506007211713401*^9, 3.5060072183600473`*^9}, {
  3.506007307668482*^9, 3.506007317571734*^9}, {3.506007372757161*^9, 
  3.5060073803732443`*^9}, {3.506604709403433*^9, 3.506604713088533*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"fX", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], "=", 
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", "x"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.506007263931981*^9, 3.5060073454938707`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"fY", "[", 
