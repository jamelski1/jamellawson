Cell[CellGroupData[{

Cell["\<\
b)  Compute the implicit equation of the line tangent to this contour at this \
point.\
\>", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"z", "=", 
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Delta]", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"contours", "=", 
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{"f", "[", 
