Cell[CellGroupData[{

Cell["c)  Plot the tangent line.", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "=", 
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Delta]", "=", 
    RowBox[{"1", "/", "10"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"singleCurve", "=", 
    RowBox[{"ContourPlot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{"x", "+", "dx"}], ",", 
         RowBox[{"y", "+", "dy"}]}], "]"}], "\[Equal]", 
       RowBox[{"f", "[", 
        RowBox[{"x", ",", "y"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"dx", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"dy", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"ContourStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Green"}], 
        "}"}]}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<dx\>\"", ",", "\"\<dy\>\""}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"singleLine", "=", 
    RowBox[{"ContourPlot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"dz", "[", 
        RowBox[{"dx", ",", "dy"}], "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{"{", 
       RowBox[{"dx", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"dy", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"ContourStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"AbsoluteThickness", "[", "2", "]"}], ",", "Magenta"}], 
        "}"}]}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<dx\>\"", ",", "\"\<dy\>\""}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"dFrame2D", "[", "\[Delta]", "]"}], ",", "singleCurve", ",", 
    "singleLine", ",", 
    RowBox[{"Arrow2D", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"gradf", "[", 
        RowBox[{"x", ",", "y"}], "]"}], "/", "30"}], ",", "Orange"}], "]"}]}],
    "}"}], "]"}]}], "Input",
