Cell[CellGroupData[{

Cell["Jamel Lamel & T.A. Colin", "Section",
 CellChangeTimes->{{3.506622897866425*^9, 3.506622901919842*^9}, {
  3.507932484753155*^9, 3.5079325039350624`*^9}}],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"Cos", "[", 
      RowBox[{
       SuperscriptBox["x", "2"], "-", "x"}], "]"}], 
     RowBox[{"1", "+", 
      SuperscriptBox["y", "2"]}]], "-", 
    RowBox[{
     FractionBox["1", "2"], " ", "x", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"3", " ", "y"}], "]"}]}]}]}], TraditionalForm]]]], "Text",
 CellChangeTimes->{3.5066227129807568`*^9}],

Cell[CellGroupData[{

Cell[TextData[{
 "a)  Draw the contour of the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], TraditionalForm]]],
 " through the point ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", ",", "y"}], ")"}], "=", 
    RowBox[{"(", 
     RowBox[{"2", ",", "1"}], ")"}]}], TraditionalForm]]],
 ". "
}], "Text"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"fX", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], ",", "x"}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fY", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", 
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], ",", "y"}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gradf", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"fX", "[", 
       RowBox[{"x", ",", "y"}], "]"}], ",", 
      RowBox[{"fY", "[", 
       RowBox[{"x", ",", "y"}], "]"}]}], "}"}]}]}]}]], "Input",
 CellChangeTimes->{{3.507933584322204*^9, 3.507933673621357*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "x", ",", "y", ",", "dx", ",", "dy", ",", "f", ",", "fX", ",", "fY", ",",
       "gradf"}], "]"}], ";"}], "\n", 
   RowBox[{"Needs", "[", "\"\<iMultiCalc`iMCUtilities`\>\"", "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"Cos", "[", 
       RowBox[{
        SuperscriptBox["x", "2"], "-", " ", "x"}], "]"}], 
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox["y", "2"]}]], " ", "-", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "/", "2"}], ")"}], 
      RowBox[{"Sin", "[", 
       RowBox[{"3", "y"}], "]"}]}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"x", "=", "2"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"y", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"z", "=", 
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Delta]", "=", "2"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"contours", "=", 
    RowBox[{"ContourPlot", "[", 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{
        RowBox[{"x", "+", "dx"}], ",", 
        RowBox[{"y", "+", "dy"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"dx", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"dy", ",", 
        RowBox[{"-", "\[Delta]"}], ",", "\[Delta]"}], "}"}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"\"\<dx\>\"", ",", "\"\<dy\>\""}], "}"}]}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.5073938860442095`*^9, 3.5073940308214893`*^9}, {
  3.507394144334366*^9, 3.507394220545251*^9}, {3.507394345509261*^9, 
  3.507394368161913*^9}}],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"Cos", "[", 
    RowBox[{"x", "-", 
     SuperscriptBox["x", "2"]}], "]"}], 
   RowBox[{"1", "+", 
    SuperscriptBox["y", "2"]}]], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "x", " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"3", " ", "y"}], "]"}]}]}]], "Output",
 CellChangeTimes->{3.5073943824212265`*^9, 3.507933199294388*^9}],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"Cos", "[", "2", "]"}], "2"], "-", 
  RowBox[{"Sin", "[", "3", "]"}]}]], "Output",
 CellChangeTimes->{3.5073943824212265`*^9, 3.507933199294388*^9}],

